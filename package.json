{
  "name": "dumbcoding-template-app",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --grep @a11y",
    "format": "biome format",
    "lint": "biome lint",
    "check:circular": "dependency-cruiser -c tooling/dependency-cruiser.config.mjs src tooling",
    "biome:check": "biome check",
    "biome:fix": "biome check --write .",
    "test:agents": "node tooling/scripts/agent-contract-smoke-test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "node tooling/scripts/verify-smart.mjs",
    "verify:all": "pnpm biome:check && pnpm typecheck && pnpm test:coverage && pnpm test:e2e && pnpm check:circular"
  },
  "dependencies": {
    "@ark-ui/react": "5.37.2",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-devtools": "0.10.7",
    "@tanstack/react-form": "1.33.0",
    "@tanstack/react-pacer": "0.22.1",
    "@tanstack/react-query": "5.101.1",
    "@tanstack/react-query-devtools": "5.101.1",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.14.3",
    "@tanstack/router-plugin": "1.168.18",
    "axios": "1.18.1",
    "lucide-react": "0.545.0",
    "nitro": "3.0.260610-beta",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@biomejs/biome": "2.4.5",
    "@playwright/test": "1.61.1",
    "@tailwindcss/typography": "0.5.20",
    "@tanstack/devtools-vite": "0.8.0",
    "@tanstack/router-cli": "1.167.17",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "dependency-cruiser": "17.4.3",
    "jsdom": "28.1.0",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
