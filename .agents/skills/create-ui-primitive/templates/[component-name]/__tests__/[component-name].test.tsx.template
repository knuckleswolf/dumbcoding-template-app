import { describe, it, expect } from 'vitest';
import { render, screen } from '@testing-library/react';
import { {{ComponentName}}, {{ComponentName}}Root } from '../{{component-name}}';

describe('{{ComponentName}}', () => {
  it('renders children', () => {
    render(<{{ComponentName}}.Root>Test content</{{ComponentName}}.Root>);
    expect(screen.getByText('Test content')).toBeInTheDocument();
  });

  it('applies size variant', () => {
    const { container } = render(
      <{{ComponentName}}Root size="lg">Content</{{ComponentName}}Root>
    );
    expect(container.firstChild).toBeInTheDocument();
  });

  it('applies style variant', () => {
    const { container } = render(
      <{{ComponentName}}Root variant="solid">Content</{{ComponentName}}Root>
    );
    expect(container.firstChild).toBeInTheDocument();
  });

  it('applies tone variant', () => {
    const { container } = render(
      <{{ComponentName}}Root tone="accent">Content</{{ComponentName}}Root>
    );
    expect(container.firstChild).toBeInTheDocument();
  });

  it('applies custom className', () => {
    const { container } = render(
      <{{ComponentName}}Root className="custom-class">Content</{{ComponentName}}Root>
    );
    expect(container.firstChild).toHaveClass('custom-class');
  });
});
