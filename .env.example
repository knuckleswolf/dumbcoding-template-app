# Public application origin used for absolute URLs, metadata, sitemap, robots, and callbacks.
VITE_PUBLIC_APP_URL=http://localhost:3000

# Example API base URL for future API domains. Keep real values in .env.local or deployment secrets.
VITE_API_BASE_URL=http://localhost:3000/api

# Server runtime binding. These are safe defaults, not secrets.
HOST=0.0.0.0
PORT=3000
